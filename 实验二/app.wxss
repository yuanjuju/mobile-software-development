.container{
  height:80vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-around;
}
/*区域四整体样式*/
.detail{
  width: 100%;
  display: flex;
  flex-direction: column;
}
/*区域四单元行样式*/
.bar{
  display: flex;
  flex-direction: row;
  margin: 20rpx 0;
}
/*区域四单元格样式*/
.box{
  width: 33.3%;
  text-align: center;
}